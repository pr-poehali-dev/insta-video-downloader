{
  "tests": [
    {
      "name": "OPTIONS CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Empty url returns 400",
      "method": "POST",
      "path": "/",
      "body": {"url": ""},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    },
    {
      "name": "Non-instagram url returns 400",
      "method": "POST",
      "path": "/",
      "body": {"url": "https://youtube.com/watch?v=abc"},
      "expectedStatus": 400,
      "expectedBody": {"error": "string"},
      "bodyMatcher": "partial"
    }
  ]
}
